{
  "name": "slg1.0",
  "private": true,
  "version": "0.0.1",
  "description": "King of World (KOW) - 全栈TypeScript网页SLG",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "build:shared": "npm run build -w @slg/shared",
    "build:server": "npm run build -w @slg/server",
    "build:client": "npm run build -w @slg/client",
    "build": "npm run build:shared && npm run build:server && npm run build:client",
    "dev:server": "npm run dev -w @slg/server",
    "start": "node packages/server/dist/main.js",
    "test:server": "npm run test -w @slg/server",
    "lint": "npm run lint -w @slg/server",
    "reset:season": "node --import tsx packages/server/src/admin.ts --mode=season",
    "reset:respawn": "node --import tsx packages/server/src/admin.ts --mode=respawn",
    "wipe:all": "node --import tsx packages/server/src/admin.ts --mode=wipe"
  }
}
